# ── Participant Configuration ────────────────────────────────────────────────
# Copy this file to .env and update the values below.
#
#   cp .env.template .env
#
# Set MY_HOST to your machine's IP address (not localhost)
MY_HOST=192.168.1.XXX
PARTICIPANT_NAME=team-name

# ── Central EDC ─────────────────────────────────────────────────────────────
# Set CENTRAL_HOST to the IP of the machine running the central EDC
CENTRAL_HOST=172.25.220.5
CENTRAL_PARTICIPANT_ID=hackfest-central
# The central connector's DSP protocol port (see central-edc/docker-compose.yml)
CENTRAL_PROTOCOL_PORT=20002

# ── Peer exchange (Task 5) ────────────────────────────────────────────────────
# The other participant you pull a dataset from. Ask them for their machine's IP
# and the asset id they registered (printed by their tr02_s1_register.py run, or
# shown in their Catalog UI). Both are required by tr02_s3_pull_peer.py.
PEER_HOST=192.168.1.XXX
PEER_ASSET_ID=

# ── Local S3 (RustFS) ──────────────────────────────────────────────────────
# Host-published RustFS port (container stays on 9000 internally)
S3_HOST_PORT=21004
S3_ACCESS=participant-admin
S3_SECRET=participant-secret-2024

# ── EDC Ports ───────────────────────────────────────────────────────────────
EDC_MGMT_PORT=21001
EDC_PROTOCOL_PORT=21002
