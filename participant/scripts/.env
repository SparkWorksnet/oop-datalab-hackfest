# ── Participant Configuration ────────────────────────────────────────────────
# Set MY_HOST to your machine's IP address (not localhost)
MY_HOST=192.168.1.10
PARTICIPANT_NAME=participant

# ── Central EDC ─────────────────────────────────────────────────────────────
# Set CENTRAL_HOST to the IP of the machine running the central EDC
CENTRAL_HOST=192.168.1.10
CENTRAL_PARTICIPANT_ID=hackfest-central

# ── Local S3 (RustFS) ──────────────────────────────────────────────────────
# Host-published RustFS port (container stays on 9000 internally)
S3_HOST_PORT=21004
S3_ACCESS=participant-admin
S3_SECRET=participant-secret-2024

# ── EDC Ports ───────────────────────────────────────────────────────────────
EDC_MGMT_PORT=21001
EDC_PROTOCOL_PORT=21002
